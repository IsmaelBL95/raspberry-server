## Ejemplo de configuración para el servidor Express.
# Puerto en el que escuchará la aplicación.
PORT=5000

# Clave raíz para la autenticación.
ROOT_KEY=0123456789abcdef

# Secreto para la firma de tokens JWT de la sesión raíz.
JWT_ROOT_SECRET=my-super-secret-jwt-key

# URI de conexión a MongoDB (opcional).
MONGO_URI=mongodb://adminuser:adminpassword@localhost:27017/?authSource=admin

# Entorno de ejecución: development o production.
NODE_ENV=development